{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction",
  "type": "object",
  "required": [
    "transaction_id",
    "produced_at",
    "event_time",
    "account_id",
    "card_id",
    "amount",
    "channel",
    "location_name",
    "status"
  ],
  "properties": {
    "transaction_id": {
      "type": "string",
      "format": "uuid"
    },
    "produced_at": {
      "type": "string",
      "format": "date-time",
      "description": "Wall-clock time when the message was produced to Kafka (UTC ISO-8601)"
    },
    "event_time": {
      "type": "string",
      "format": "date-time",
      "description": "Actual time the transaction occurred — may differ from produced_at by ±2s"
    },
    "account_id": {
      "type": "string",
      "pattern": "^(ACC_[0-9]{5}|FRD_[A-Z0-9_]+)$"
    },
    "card_id": {
      "type": "string",
      "pattern": "^(CARD|FRD_CARD)_[0-9]{5}$"
    },
    "amount": {
      "type": "number",
      "description": "Transaction amount in VND"
    },
    "channel": {
      "type": "string",
      "enum": ["ATM", "POS", "ONLINE"]
    },
    "location_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["Approved", "Declined"]
    }
  },
  "additionalProperties": false
}
