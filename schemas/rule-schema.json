{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FraudRule",
  "type": "object",
  "required": [
    "rule_id",
    "field",
    "operator",
    "action",
    "enabled"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "field": {
      "type": "string",
      "enum": ["amount", "account_id"]
    },
    "operator": {
      "type": "string",
      "enum": ["GT", "GTE", "LT", "LTE", "EQ", "NEQ"]
    },
    "threshold": {
      "type": "integer",
      "description": "Used when field=amount"
    },
    "value": {
      "type": "string",
      "description": "Used when field=account_id"
    },
    "action": {
      "type": "string",
      "enum": ["BLOCK", "ALERT"]
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
