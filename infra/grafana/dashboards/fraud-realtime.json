{
  "title": "Fraud Detection — Real-Time",
  "uid": "fraud-realtime",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-5m", "to": "now" },
  "timezone": "utc",
  "tags": ["fraud", "clickhouse", "realtime"],
  "panels": [
    {
      "id": 1,
      "title": "Total Transactions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT count() AS Total FROM fraud_detection.transactions WHERE account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' AND $__timeFilter(produced_at)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }
      }
    },
    {
      "id": 2,
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT round(avg(dateDiff('millisecond', produced_at, decided_at)), 0) AS AvgLatency FROM fraud_detection.transactions WHERE account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' AND $__timeFilter(produced_at)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT round(quantile(0.99)(dateDiff('millisecond', produced_at, decided_at)), 0) AS P99 FROM fraud_detection.transactions WHERE account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' AND $__timeFilter(produced_at)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Throughput In (tx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 0,
          "rawSql": "SELECT toStartOfSecond(produced_at) AS time, count() AS ThroughputIn FROM fraud_detection.transactions WHERE $__timeFilter(produced_at) AND account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 5,
      "title": "Throughput Out (tx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 0,
          "rawSql": "SELECT toStartOfSecond(decided_at) AS time, count() AS ThroughputOut FROM fraud_detection.transactions WHERE $__timeFilter(decided_at) AND account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 6,
      "title": "Latency Percentiles (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "DS_CLICKHOUSE" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 0,
          "rawSql": "SELECT toStartOfSecond(decided_at) AS time, quantile(0.50)(dateDiff('millisecond', produced_at, decided_at)) AS p50, quantile(0.90)(dateDiff('millisecond', produced_at, decided_at)) AS p90, quantile(0.99)(dateDiff('millisecond', produced_at, decided_at)) AS p99, max(dateDiff('millisecond', produced_at, decided_at)) AS max_ms FROM fraud_detection.transactions WHERE $__timeFilter(decided_at) AND account_id NOT LIKE 'FRD_RULE_UPDATE_ACC_%' GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "max_ms" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "p99" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "p90" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "p50" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ]
}
